# AIShield V2 — Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1

# JWT
JWT_SECRET_KEY=another-long-random-jwt-secret

# Database (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/aishield
DATABASE_URL=sqlite:///aishield.db

# Scanner settings
BLOCK_THRESHOLD=30
MAX_UPLOAD_MB=32

# ── OAuth Configuration (Optional) ──────────────────────
# Required for Google and GitHub Login
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional: Ollama LLM (Phase 4)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
USE_LLM=false

# Optional: VirusTotal API (Phase 8)
# VIRUSTOTAL_API_KEY=your-key-here
